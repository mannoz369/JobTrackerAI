# Shared local environment template.
# Copy only the values needed by each process into backend/.env or frontend/.env.

APP_ENV=local

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGODB_DATABASE=jobtracker

# Backend
APP_NAME=JobTracker API
ENVIRONMENT=local
CORS_ORIGINS=["http://localhost:3000"]
FRONTEND_APP_URL=http://localhost:3000
SESSION_SECRET_KEY=<generate-a-long-random-session-secret>
TOKEN_ENCRYPTION_KEY=<generate-a-fernet-key-or-long-random-secret>
AUTH_COOKIE_SECURE=false

# Frontend
NEXT_PUBLIC_APP_NAME=JobTracker
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Google OAuth and Gmail API
GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Google Pub/Sub
GOOGLE_CLOUD_PROJECT=<google-cloud-project-id>
GMAIL_PUBSUB_TOPIC=projects/<google-cloud-project-id>/topics/<topic-id>
GMAIL_PUBSUB_SUBSCRIPTION=projects/<google-cloud-project-id>/subscriptions/<subscription-id>
GMAIL_PUBSUB_VERIFICATION_TOKEN=<optional-push-url-token>
GMAIL_WATCH_LABEL_IDS=INBOX
GMAIL_BACKFILL_PAGE_SIZE=25
GMAIL_BACKFILL_API_MAX_RETRIES=3
GMAIL_BACKFILL_API_RETRY_BACKOFF_SECONDS=1.0

# Gemini
GEMINI_API_KEY=<gemini-api-key>
GEMINI_MODEL=gemini-2.5-flash
EMAIL_EXTRACTION_REVIEW_CONFIDENCE_THRESHOLD=0.7
APPLICATION_MATCH_CONFIDENCE_THRESHOLD=0.82
APPLICATION_MATCH_AMBIGUITY_MARGIN=0.08
APPLICATION_AUTOCREATE_CONFIDENCE_THRESHOLD=0.9

# Render deployment
RENDER_SERVICE_NAME=<render-service-name>
RENDER_DEPLOY_HOOK_URL=<render-deploy-hook-url>
